BEGIN SCH
<Qucs Schematic 0.0.20>
<Properties>
  <View 0 0 2450 1400 1.00 0 0>
  <Grid 10 10 0>
  <Snap 10>
  <Rotator 0>
</Properties>
<SymbolLibrary>
</SymbolLibrary>

<Components>
  <!-- I/O ports ----------------------------------------------------------->
  <Port P1 1  100 300  16 16 0 2 "1"  "analog">
  <Port P2 1 2000 300  16 16 0 0 "2"  "analog">

  <!-- INPUT MATCH --------------------------------------------------------->
  <C  Cin 1  220 300  -26 17 0 0 "0.50 pF" "" "0402">
  <L  Lin 1  340 300  -26 17 0 0 "0.30 nH" "" "0402">
  <R  Rstab 1 340 240  -26 17 1 1 "10 Ω"   "" "0402">   <!-- gate damping -->
  <C  Cgnd 1 340 180  -26 17 0 0 "10 pF"  "" "0402">   <!-- RF ground -->

  <!-- GATE BIAS ----------------------------------------------------------->
  <Vdc Vg  1  520 120   18 -26 0 1 "-2.8 V" 1>
  <R   Rg  1  520 200  -26 17 0 0 "1 kΩ"   "" "0603">
  <GND *   1  520  60    0   0 0 0>

  <!-- ACTIVE DEVICE ------------------------------------------------------->
  <HEMT T1 1  720 300    8 -26 0 0 "TGF2023-2-02"  "ModelFile">

  <!-- DRAIN BIAS & BYPASS ------------------------------------------------->
  <L  Lrf  1  880 240  -26 17 0 0 "15 nH"  "" "0603">   <!-- RF choke -->
  <Vdc Vdd 1 1040 120   18 -26 0 1 "28 V"  1>
  <C   Cb1 1 1040 200  -26 17 0 0 "100 pF" "" "0603">
  <C   Cb2 1 1090 200  -26 17 0 0 "1 nF"   "" "0603">
  <C   Cb3 1 1140 200  -26 17 0 0 "10 µF"  "" "0603">
  <GND *   1 1040  60    0   0 0 0>

  <!-- OUTPUT MATCH -------------------------------------------------------->
  <L  Lout 1  880 300  -26 17 0 0 "0.50 nH" "" "0402">
  <C  Cout 1  980 360  -26 17 0 0 "1.20 pF" "" "0402">
  <C  Cblk 1 1120 300  -26 17 0 0 "0.50 pF" "" "0402">

  <!-- REFERENCE GROUNDS --------------------------------------------------->
  <GND *   1 340  60    0 0 0 0>
  <GND *   1  980 420   0 0 0 0>
</Components>

<Wires>
  <!-- Input line -->
  100 300 220 300
  220 300 340 300
  <!-- Gate series R -->
  340 260 340 240
  <!-- Gate ground bypass -->
  340 200 340 180
  340 180 340  60
  <!-- Gate bias network -->
  520 200 520 300
  520 200 340 200
  520 120 520 200
  520  60 520  60
  <!-- Transistor connections -->
  340 300 720 300       <!-- Gate -->
  720 240 880 240       <!-- Drain bias RFC -->
  880 240 880 300       <!-- RFC to drain -->
  1040 200 1040 300     <!-- bypass Cb1 -->
  1040 200 1090 200
  1090 200 1140 200
  1040 120 1040 200
  1040  60 1040  60
  <!-- Output matching -->
  880 300 980 300       <!-- series L -->
  980 300 1120 300      <!-- coupling cap -->
  980 300 980 360       <!-- shunt C -->
  980 360 980 420
  1120 300 2000 300     <!-- to output port -->
</Wires>

<Diagrams>
</Diagrams>

<Paintings>
  <Text 150  40 12 #000000 0 "Common‑Source GaN HEMT PA  — 6 GHz centre">
  <Text 150  70 10 #000000 0 "All passives are 0402 / 0603; tweak values to refine match">
</Paintings>
END SCH
